# =====================================================================
#  .env.local  -  configuracao LOCAL do frontend Next.js
#  ---------------------------------------------------------------------
#  IMPORTANTE: este ficheiro e um TEMPLATE. Copia-o para `.env.local`
#  antes de editar e NUNCA comites o .env.local (ja esta em .gitignore).
#
#      cp .env.example .env.local
#      editar .env.local   (cola a tua chave do Google Maps)
#      npm run dev         (reinicia para o Next.js ler NEXT_PUBLIC_*)
# =====================================================================


# ---------------------------------------------------------------------
# 1) Endereco do backend Strapi
# ---------------------------------------------------------------------
# dev:  http://localhost:1337
# prod: https://o-teu-projeto.strapiapp.com
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337


# ---------------------------------------------------------------------
# 2) Chave da API do Google Maps (Maps JavaScript API)
# ---------------------------------------------------------------------
# Cola aqui a tua chave (comeca por AIza...).
# Como obtê-la: https://console.cloud.google.com/google/maps-apis/credentials
# Em prod: restringe a chave por HTTP referrer (*.vercel.app) + Maps JS API only.
#
# >>> SUBSTITUI O PLACEHOLDER PELA TUA CHAVE REAL <<<
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyAq6ARgrFVuOuYflIwDeNJyS5zqm0XTTKM


# ---------------------------------------------------------------------
# 3) NextAuth.js v5
# ---------------------------------------------------------------------
# Dev: podes deixar vazio (app gera fallback aleatorio + warning).
# Prod: gera com `npx auth secret` ou `openssl rand -base64 32`.
AUTH_SECRET=

# Em dev aceita hosts locais (localhost, 127.0.0.1). Em prod por tras
# de Vercel/proxy deixa `true`.
AUTH_TRUST_HOST=true
